        <surveyls_survey_id><![CDATA[33263]]></surveyls_survey_id>
        <surveyls_language>zh-Hant-TW</surveyls_language>
        <surveyls_title>ESP 功能測試問卷（繁體中文）</surveyls_title>
        <surveyls_description>此問卷用於測試 LimeSurvey 的多題型、圖片顯示與附件上傳功能。</surveyls_description>
        <surveyls_welcometext>歡迎使用 ESP 測試問卷，請依序完成各題。</surveyls_welcometext>
        <surveyls_endtext>感謝填答，測試完成。</surveyls_endtext>
        <surveyls_url><![CDATA[]]></surveyls_url>
        <surveyls_urldescription><![CDATA[]]></surveyls_urldescription>
        <surveyls_email_invite_subj><![CDATA[邀請您參與問卷]]></surveyls_email_invite_subj>
        <surveyls_email_invite><![CDATA[親愛的 {FIRSTNAME}：<br /><br />誠摯邀請您參與以下問卷：<br />「{SURVEYNAME}」<br /><br />{SURVEYDESCRIPTION}<br /><br />請點擊下方連結開始填答：<br />{SURVEYURL}<br /><br />如不希望再收到邀請，請點擊：<br />{OPTOUTURL}<br /><br />{ADMINNAME} ({ADMINEMAIL})]]></surveyls_email_invite>
        <surveyls_email_remind_subj><![CDATA[提醒您完成問卷]]></surveyls_email_remind_subj>
        <surveyls_email_remind><![CDATA[親愛的 {FIRSTNAME}：<br /><br />提醒您，以下問卷尚未完成：<br />「{SURVEYNAME}」<br /><br />{SURVEYDESCRIPTION}<br /><br />請點擊連結繼續填答：<br />{SURVEYURL}<br /><br />如不希望再收到提醒，請點擊：<br />{OPTOUTURL}<br /><br />{ADMINNAME} ({ADMINEMAIL})]]></surveyls_email_remind>
        <surveyls_email_register_subj><![CDATA[問卷註冊確認]]></surveyls_email_register_subj>
        <surveyls_email_register><![CDATA[親愛的 {FIRSTNAME}：<br /><br />您已註冊參與問卷：{SURVEYNAME}<br /><br />請點擊以下連結開始填答：<br />{SURVEYURL}<br /><br />若您並未提出註冊，請聯絡 {ADMINNAME}（{ADMINEMAIL}）。]]></surveyls_email_register>
        <surveyls_email_confirm_subj><![CDATA[問卷完成確認]]></surveyls_email_confirm_subj>
        <surveyls_email_confirm><![CDATA[親愛的 {FIRSTNAME}：<br /><br />您已完成問卷「{SURVEYNAME}」，作答結果已儲存。感謝您的參與。<br /><br />如有疑問請聯絡 {ADMINNAME}（{ADMINEMAIL}）。]]></surveyls_email_confirm>
